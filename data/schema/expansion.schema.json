{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/shaheersinn/Middle-East-Jobs-Tracker/data/schema/expansion.schema.json",
  "title": "Law Firm Expansion Record",
  "description": "Schema for a single law-firm expansion event in the Middle East tracker.",
  "type": "object",
  "required": [
    "record_id",
    "firm_name",
    "expansion_type",
    "practice_areas",
    "country",
    "announced_date",
    "source_url",
    "source_type",
    "confidence",
    "status",
    "created_at",
    "last_modified",
    "schema_version"
  ],
  "additionalProperties": false,
  "properties": {
    "record_id": {
      "type": "string",
      "description": "Unique slug. Lowercase letters, digits, and hyphens only.",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "firm_name": {
      "type": "string",
      "description": "Full canonical name of the law firm. UTF-8, preserve diacritics.",
      "minLength": 1
    },
    "expansion_type": {
      "type": "string",
      "description": "Type of expansion event.",
      "enum": [
        "new_office",
        "new_practice_group",
        "merger",
        "lateral_hire_group",
        "office_relocation",
        "office_expansion",
        "strategic_alliance",
        "new_jurisdiction_license",
        "department_restructure"
      ]
    },
    "practice_areas": {
      "type": "array",
      "description": "One or more practice areas from the controlled vocabulary.",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "Corporate & M&A",
          "Private Equity",
          "Capital Markets",
          "Banking & Finance",
          "Real Estate",
          "Litigation & Dispute Resolution",
          "Arbitration & Mediation",
          "Intellectual Property",
          "Technology & Cybersecurity",
          "Data Privacy & Protection",
          "Employment & Labor",
          "Tax",
          "Regulatory & Compliance",
          "Antitrust & Competition",
          "White Collar & Investigations",
          "Healthcare & Life Sciences",
          "Energy & Natural Resources",
          "Environmental",
          "Infrastructure & Projects",
          "Restructuring & Insolvency",
          "Immigration",
          "Family & Private Client",
          "Public Law & Government Affairs",
          "Trade & Customs"
        ]
      }
    },
    "country": {
      "type": "string",
      "description": "ISO 3166-1 alpha-2 country code (e.g. AE, GB, US).",
      "pattern": "^[A-Z]{2}$"
    },
    "region": {
      "type": "string",
      "description": "Human-readable region (e.g. 'Middle East', 'GCC')."
    },
    "city": {
      "type": "string",
      "description": "City name. Preserve original diacritics."
    },
    "announced_date": {
      "type": "string",
      "description": "ISO 8601 date of first known public announcement (YYYY-MM-DD).",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "effective_date": {
      "type": "string",
      "description": "ISO 8601 date when the change takes effect (YYYY-MM-DD).",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "source_url": {
      "type": "string",
      "description": "Main supporting source URL.",
      "format": "uri",
      "pattern": "^https?://"
    },
    "source_type": {
      "type": "string",
      "description": "Category of the main source.",
      "enum": [
        "firm_press_release",
        "legal_directory",
        "legal_news",
        "court_filing",
        "job_posting",
        "industry_report",
        "social_media",
        "other"
      ]
    },
    "confidence": {
      "type": "string",
      "description": "Confidence level in the accuracy of this record.",
      "enum": [
        "confirmed",
        "high",
        "medium",
        "low",
        "unverified"
      ]
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status of this record.",
      "enum": [
        "draft",
        "under_review",
        "verified",
        "published",
        "archived"
      ]
    },
    "headcount": {
      "type": "integer",
      "description": "Number of people involved, if known.",
      "minimum": 1
    },
    "related_records": {
      "type": "array",
      "description": "record_id values of logically related records.",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
      }
    },
    "tags": {
      "type": "array",
      "description": "Supplemental labels for filtering (free-form, lowercase).",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string",
      "description": "Free-form notes. Preferred maximum 500 characters.",
      "maxLength": 1000
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 UTC datetime when the record was first created.",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "last_modified": {
      "type": "string",
      "description": "ISO 8601 UTC datetime when the record was last modified.",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "schema_version": {
      "type": "string",
      "description": "Semantic version of the schema used by this record (e.g. 1.0.0).",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_by": {
      "type": "string",
      "description": "GitHub username or automation ID that created this record."
    }
  }
}
